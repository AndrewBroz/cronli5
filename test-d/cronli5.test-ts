import {expectType, expectError, expectAssignable} from 'tsd';
import cronli5, {Cronli5Options, CronPattern, CronPatternObject} from '..';
import es from '../types/lang/es/index.js';

// The default export is a function returning a string.
expectType<string>(cronli5('* * * * *'));
expectType<string>(cronli5('* * * * *', {ampm: false}));
expectType<string>(cronli5(['*/5', '*', '*', '*', '*']));
expectType<string>(cronli5({minute: '*/5'}));
expectType<string>(cronli5({second: 0, minute: 30, hour: 9}));

// All three pattern shapes are assignable to CronPattern.
expectAssignable<CronPattern>('* * * * *');
expectAssignable<CronPattern>(['*', '*', '*', '*', '*']);
expectAssignable<CronPattern>({minute: '*/5'});
expectAssignable<CronPatternObject>({hour: 9, weekday: 'MON-FRI'});

// Options are all optional.
expectAssignable<Cronli5Options>({});
expectAssignable<Cronli5Options>({
  ampm: true,
  dialect: 'uk',
  lenient: false,
  short: false,
  seconds: false,
  years: true
});

// The pattern argument is required.
expectError(cronli5());

// Unknown option keys are rejected.
expectError<Cronli5Options>({nope: true});

// Unknown dialects are rejected.
expectError<Cronli5Options>({dialect: 'fr'});

// Named and custom-object dialects are accepted; unknown style fields are
// rejected.
expectAssignable<Cronli5Options>({dialect: 'house'});
// Spanish regional dialects are accepted (names are language-scoped).
expectAssignable<Cronli5Options>({dialect: 'es-MX'});
expectAssignable<Cronli5Options>({dialect: 'es-US'});
expectAssignable<Cronli5Options>({dialect: 'es-AR'});
expectAssignable<Cronli5Options>({dialect: 'es-ES'});
expectAssignable<Cronli5Options>({dialect: {through: ' until '}});
expectAssignable<Cronli5Options>({
  dialect: {am: 'am', closeUp: true, ordinals: true, serialComma: false}
});
expectError<Cronli5Options>({dialect: {nope: true}});

// Numbers are not valid patterns.
expectError(cronli5(42));

// A language module (the shape every `cronli5/lang/<code>` subpath
// declares) is assignable to the `lang` option.
expectAssignable<Cronli5Options>({lang: es});
expectType<string>(cronli5('* * * * *', {lang: es}));
