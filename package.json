{
  "name": "cronli5",
  "version": "0.1.0",
  "description": "Cron Like I'm Five: A Cron to English Utility",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewbroz/cronli5.git"
  },
  "type": "module",
  "main": "./dist/cronli5.cjs",
  "module": "./dist/cronli5.js",
  "types": "./cronli5.d.ts",
  "browser": "./cronli5.min.js",
  "exports": {
    ".": {
      "types": "./cronli5.d.ts",
      "import": "./dist/cronli5.js",
      "require": "./dist/cronli5.cjs"
    },
    "./lang/en": {
      "types": "./lang.d.ts",
      "import": "./dist/lang/en.js",
      "require": "./dist/lang/en.cjs"
    },
    "./lang/es": {
      "types": "./lang.d.ts",
      "import": "./dist/lang/es.js",
      "require": "./dist/lang/es.cjs"
    },
    "./lang/fi": {
      "types": "./lang.d.ts",
      "import": "./dist/lang/fi.js",
      "require": "./dist/lang/fi.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "cronli5": "cli.js"
  },
  "files": [
    "dist",
    "src",
    "cli.js",
    "cronli5.min.js",
    "cronli5.d.ts",
    "lang.d.ts",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs",
    "docs": "node scripts/docs.mjs",
    "lint": "eslint src test cli.js eslint.config.js scripts",
    "lint:fix": "eslint src test cli.js eslint.config.js scripts --fix",
    "test": "mocha",
    "test:types": "tsd",
    "coverage": "c8 mocha",
    "prepublishOnly": "npm run lint && npm run test:types && npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cron",
    "crontab"
  ],
  "author": {
    "name": "Andrew Brož",
    "email": "andrew.broz@gmail.com",
    "url": "https://github.com/andrewbroz"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.15.0",
    "c8": "^10.1.3",
    "chai": "^4.5.0",
    "cronstrue": "^3.14.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.15.0",
    "fast-check": "^3.23.1",
    "globals": "^15.12.0",
    "mocha": "^11.0.1",
    "tsd": "^0.31.2",
    "typescript": "^6.0.3"
  },
  "tsd": {
    "directory": "test-d"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.5"
  }
}
