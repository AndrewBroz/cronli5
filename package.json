{
  "name": "cronli5",
  "version": "0.5.0",
  "description": "Cron Like I'm Five: A Cron to English Utility",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/andrewbroz/cronli5.git"
  },
  "type": "module",
  "main": "./dist/cronli5.cjs",
  "module": "./dist/cronli5.js",
  "types": "./types/cronli5.d.ts",
  "browser": "./cronli5.min.js",
  "exports": {
    ".": {
      "types": "./types/cronli5.d.ts",
      "import": "./dist/cronli5.js",
      "require": "./dist/cronli5.cjs"
    },
    "./lang/de": {
      "types": "./types/lang/de/index.d.ts",
      "import": "./dist/lang/de.js",
      "require": "./dist/lang/de.cjs"
    },
    "./lang/en": {
      "types": "./types/lang/en/index.d.ts",
      "import": "./dist/lang/en.js",
      "require": "./dist/lang/en.cjs"
    },
    "./lang/es": {
      "types": "./types/lang/es/index.d.ts",
      "import": "./dist/lang/es.js",
      "require": "./dist/lang/es.cjs"
    },
    "./lang/fi": {
      "types": "./types/lang/fi/index.d.ts",
      "import": "./dist/lang/fi.js",
      "require": "./dist/lang/fi.cjs"
    },
    "./lang/pt": {
      "types": "./types/lang/pt/index.d.ts",
      "import": "./dist/lang/pt.js",
      "require": "./dist/lang/pt.cjs"
    },
    "./lang/zh": {
      "types": "./types/lang/zh/index.d.ts",
      "import": "./dist/lang/zh.js",
      "require": "./dist/lang/zh.cjs"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "cronli5": "cli.js"
  },
  "files": [
    "dist",
    "types",
    "src",
    "cli.js",
    "cronli5.min.js",
    "README.md",
    "LICENSE.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "node scripts/build.mjs && npm run types",
    "docs": "node --import tsx scripts/docs.mjs",
    "conciseness": "node --import tsx tooling/scripts/conciseness.mjs",
    "divergence": "node --import tsx tooling/scripts/cronstrue-divergence.mjs",
    "fuzz": "node --import tsx scripts/fuzz-lang.mjs",
    "lint": "eslint src test cli.js eslint.config.js scripts tooling/scripts",
    "metamorphic": "node --import tsx tooling/scripts/metamorphic.mjs",
    "lint:fix": "eslint src test cli.js eslint.config.js scripts tooling/scripts --fix",
    "test": "vitest run",
    "types": "tsc -p tsconfig.types.json",
    "test:types": "npm run types && tsd",
    "typecheck": "tsc -p tsconfig.json",
    "coverage": "vitest run --coverage",
    "verify": "npm run lint && npm run typecheck && npm run test:types && npm test && npm run coverage && npm run conciseness && npm run docs -- --check && npm run build",
    "prepare": "node scripts/install-hooks.mjs",
    "prepublishOnly": "npm run lint && npm run typecheck && npm run test:types && npm run build && npm test"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "cron",
    "crontab"
  ],
  "author": {
    "name": "Andrew Brož",
    "email": "andrew.broz@gmail.com",
    "url": "https://github.com/andrewbroz"
  },
  "license": "MIT",
  "devDependencies": {
    "@eslint/eslintrc": "^3.2.0",
    "@eslint/js": "^9.15.0",
    "@vitest/coverage-v8": "^4.1.9",
    "chai": "^4.5.0",
    "cronstrue": "^3.14.0",
    "esbuild": "^0.28.1",
    "eslint": "^9.15.0",
    "fast-check": "^3.23.1",
    "globals": "^15.12.0",
    "tsd": "^0.31.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.9"
  },
  "tsd": {
    "directory": "test-d"
  },
  "overrides": {
    "diff": "^9.0.0",
    "serialize-javascript": "^7.0.5"
  }
}
