{
  "all": true,
  "extension": [
    ".ts"
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/browser.ts",
    "src/core/schedule.ts",
    "src/types.ts"
  ],
  "reporter": [
    "text",
    "lcov"
  ],
  "report-dir": "./coverage",
  "check-coverage": true,
  "lines": 99,
  "branches": 95,
  "functions": 97,
  "statements": 99
}
