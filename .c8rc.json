{
  "all": true,
  "extension": [
    ".ts"
  ],
  "include": [
    "src/**/*.ts"
  ],
  "exclude": [
    "src/browser.ts",
    "src/core/ir.ts",
    "src/types.ts",
    "src/lang/zh/**"
  ],
  "reporter": [
    "text",
    "lcov"
  ],
  "report-dir": "./coverage",
  "check-coverage": true,
  "lines": 99,
  "branches": 96,
  "functions": 97,
  "statements": 99
}
